# 复制此文件为 llm.yaml 并填入真实配置
# configs/llm.yaml 已加入 .gitignore，不会提交到 git

# reasoning 说明（模型特性，配在此文件而非 pipeline.yaml）：
#   true  → 启用 Agno 推理链（仅适用原生推理模型：deepseek-reasoner / OpenAI o1/o3）
#           错误开启会导致：400 role=developer / ReasoningSteps 解析失败 / Gradio 无响应崩溃
#   false → 关闭（默认，绝大多数模型）
#           qwen3 的 native thinking (<think> 块) 不受此开关影响，仍正常输出

# ── Anthropic Claude（原生集成，需 pip install anthropic）──────
provider: "anthropic"
api_key: "sk-ant-xxx"
model: "claude-sonnet-4-5-20250929"
temperature: 0.7
max_tokens: 8192
reasoning: false

# ── DeepSeek reasoner（原生推理模型，R1 思考模式）──────────────
# provider: "openai"
# api_key: "sk-xxx"
# base_url: "https://api.deepseek.com/v1"
# model: "deepseek-reasoner"
# temperature: 0.7
# max_tokens: 8192
# reasoning: true    ← 原生推理模型才能开 true

# ── 普通 OpenAI 兼容（qwen / gpt-4o / deepseek-chat 等）───────
# provider: "openai"
# api_key: "sk-xxx"
# base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
# model: "qwen3.5-27b"
# temperature: 0.6
# max_tokens: 32000
# reasoning: false   ← 必须 false！qwen3 有自己的 native thinking，不需要 Agno 推理链
#                      设为 true 会导致：22s+ 延迟、ReasoningSteps 解析报错、Gradio 崩溃
