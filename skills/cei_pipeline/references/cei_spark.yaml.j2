cei_spark:
  target_pon: "{{ target_pon }}"
  time_window: "{{ time_window }}"

  collection:
    granularity: "{{ granularity }}"
    interval_seconds: {{ 60 if granularity == "minute" else 3600 }}

  model:
    name: "{{ model }}"

  metrics:
    - bandwidth_utilization
    - packet_loss_rate
    - latency_avg
    - jitter
    - connection_stability
    - dns_resolution_time

  threshold:
    cei_score_warning: {{ threshold }}
    cei_score_critical: {{ threshold - 20 }}

  report:
    enabled: true
    frequency: hourly
