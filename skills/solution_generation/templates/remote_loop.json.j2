{
  "remote_loop": {
    "profile": {
      "user_type": "{{ user_type }}",
      "package_type": "{{ package_type }}",
      "scenario": "{{ scenario }}"
    },
    "trigger": {
      "type": "{% if complaint_history %}complaint{% else %}proactive{% endif %}",
      "time_window": "{{ time_window }}",
      "auto_trigger": true
    },
    "diagnosis_steps": [
      {
        "step_id": 1,
        "name": "连通性检测",
        "action": "ping_test",
        "params": {
          "count": 10,
          "timeout_ms": {% if package_type == "专线套餐" %}1000{% else %}3000{% endif %}
        }
      },
      {
        "step_id": 2,
        "name": "光链路检测",
        "action": "optical_check"
      },
      {
        "step_id": 3,
        "name": "带宽测速",
        "action": "speed_test",
        "params": {
          "download_target_mbps": {% if package_type == "专线套餐" %}100{% elif package_type == "直播套餐" %}50{% else %}30{% endif %},
          "upload_target_mbps": {% if scenario in ["卖场走播", "楼宇直播"] %}30{% else %}10{% endif %}
        }
      }
    ],
    "repair_priority": "{% if package_type == "专线套餐" %}critical{% elif package_type == "直播套餐" %}high{% else %}normal{% endif %}",
    "max_repair_attempts": {% if package_type == "专线套餐" %}3{% else %}2{% endif %},
    "timeout_minutes": {% if package_type == "专线套餐" %}10{% else %}15{% endif %}
  }
}
