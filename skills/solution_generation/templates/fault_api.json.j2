{
  "fault_config": {
    "profile": {
      "user_type": "{{ user_type }}",
      "package_type": "{{ package_type }}",
      "scenario": "{{ scenario }}"
    },
    "time_window": "{{ time_window }}",
    "detection_rules": [
      {
        "rule_id": "AUTO-FAULT-001",
        "name": "光功率异常检测",
        "condition": {
          "metric": "rx_optical_power_dbm",
          "operator": "less_than",
          "threshold": -25.0
        },
        "severity": "critical"
      },
      {
        "rule_id": "AUTO-FAULT-002",
        "name": "丢包率监控",
        "condition": {
          "metric": "packet_loss_rate",
          "operator": "greater_than",
          "threshold": {% if package_type == "专线套餐" %}0.005{% elif package_type == "直播套餐" %}0.01{% else %}0.03{% endif %}
        },
        "severity": "{% if package_type == "专线套餐" %}critical{% else %}major{% endif %}"
      },
      {
        "rule_id": "AUTO-FAULT-003",
        "name": "时延监控",
        "condition": {
          "metric": "latency_ms",
          "operator": "greater_than",
          "threshold": {% if scenario in ["卖场走播", "楼宇直播"] %}50{% else %}100{% endif %}
        },
        "severity": "major"
      }
    ],
    "auto_recovery": {% if package_type == "专线套餐" %}false{% else %}true{% endif %},
    "notification_level": "{% if package_type == "专线套餐" %}immediate{% else %}batch{% endif %}"
  }
}
